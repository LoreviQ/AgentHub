{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agenthub.local/schemas/agent.schema.json",
  "title": "AgentHub Agent Package",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "name",
    "description",
    "version",
    "model",
    "runtime",
    "io",
    "tools",
    "public_instructions"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "name",
        "temperature",
        "max_tokens"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "temperature": {
          "type": "number",
          "minimum": 0,
          "maximum": 2
        },
        "max_tokens": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "timeout_seconds",
        "internet_access"
      ],
      "properties": {
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "internet_access": {
          "type": "boolean"
        },
        "execution_notes": {
          "type": "string"
        }
      }
    },
    "io": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_mode",
        "output_mode"
      ],
      "properties": {
        "input_mode": {
          "type": "string",
          "enum": [
            "text"
          ]
        },
        "output_mode": {
          "type": "string",
          "enum": [
            "markdown",
            "json"
          ]
        }
      }
    },
    "tools": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "items"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/tool"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "enabled": {
                "const": false
              }
            }
          },
          "then": {
            "properties": {
              "items": {
                "maxItems": 0
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "enabled": {
                "const": true
              }
            }
          },
          "then": {
            "properties": {
              "items": {
                "minItems": 1
              }
            }
          }
        }
      ]
    },
    "public_instructions": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "description",
        "image",
        "entrypoint",
        "input_format",
        "output_format",
        "timeout_seconds"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "image": {
          "type": "string",
          "minLength": 1
        },
        "entrypoint": {
          "type": "string",
          "minLength": 1
        },
        "input_format": {
          "type": "string",
          "enum": [
            "json"
          ]
        },
        "output_format": {
          "type": "string",
          "enum": [
            "json"
          ]
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
