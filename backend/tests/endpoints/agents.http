# AgentHub API smoke tests for the VS Code REST Client extension.
# Start the backend with the "Backend API (.env.local)" launch profile first.

@host = http://127.0.0.1:8000
@api = {{host}}/api
@mcp = {{host}}/mcp/
@agentId = legal-checker

###
# Health check
GET {{host}}/health
Accept: application/json

###
# List registered agents
GET {{api}}/agents
Accept: application/json

###
# Get one known agent
GET {{api}}/agents/{{agentId}}
Accept: application/json

###
# Get the tool-enabled agent
GET {{api}}/agents/clause-extractor
Accept: application/json

###
# Execute the first demo agent
POST {{api}}/agents/legal-checker/execute
Accept: application/json
Content-Type: application/json

{
  "input": "This agreement renews automatically every 12 months unless terminated 60 days in advance. Vendor liability is capped at fees paid in the prior 3 months."
}

###
# Execute the tool-enabled agent
POST {{api}}/agents/clause-extractor/execute
Accept: application/json
Content-Type: application/json

{
  "input": "The agreement automatically renews for successive one-year terms unless either party gives 30 days notice before renewal. Either party may terminate for material breach if the breach is not cured within 15 days. Each party must keep confidential information secret and may disclose it only as required by law. Vendor liability is limited to the fees paid under this agreement during the prior 12 months."
}


###
# Not found case
GET {{api}}/agents/does-not-exist
Accept: application/json

###
# MCP endpoint smoke check
POST {{mcp}}
Accept: application/json, text/event-stream
Content-Type: application/json

{}
