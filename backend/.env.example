# AgentHub backend environment reference.
#
# This file is documentation plus a safe copy template.
# Copy it to `.env.local` for local VS Code/dev execution or `.env.prod` for
# Docker/Coolify-style container execution. The backend does not read this file
# directly. Your execution context must load it.
#
# Naming:
# All settings use the `AGENTHUB_` prefix.
#
# Default status:
# - "Default" means the app already has a built-in default in `config.py`.
# - "Required override" means you should set it in `.env.local` for your environment.

# AGENTHUB_APP_NAME
# Purpose: FastAPI application title.
# Default: "AgentHub Backend"
# Acceptable examples:
#   AGENTHUB_APP_NAME=AgentHub Backend
#   AGENTHUB_APP_NAME=AgentHub Local API
AGENTHUB_APP_NAME=AgentHub Backend

# AGENTHUB_API_PREFIX
# Purpose: URL prefix for API routes.
# Default: "/api"
# Acceptable examples:
#   AGENTHUB_API_PREFIX=/api
#   AGENTHUB_API_PREFIX=/v1
AGENTHUB_API_PREFIX=/api

# AGENTHUB_DATABASE_URL
# Purpose: SQLAlchemy database connection string.
# Default: none
# Required override: yes
# Acceptable examples:
#   AGENTHUB_DATABASE_URL=postgresql+psycopg://agenthub:agenthub@localhost:5432/agenthub
#   AGENTHUB_DATABASE_URL=postgresql+psycopg://agenthub:agenthub@postgres:5432/agenthub
#   AGENTHUB_DATABASE_URL=sqlite:////tmp/agenthub.db
AGENTHUB_DATABASE_URL=postgresql+psycopg://agenthub:agenthub@localhost:5432/agenthub

# OPENROUTER_API_KEY
# Purpose: API key used by the shared LLM runtime for OpenRouter-backed execution.
# Default: none
# Required override: yes for `POST /api/agents/:id/execute` against real models
# Acceptable examples:
#   OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_API_KEY=

# AGENTHUB_TOOL_IMAGE_TAG_PREFIX
# Purpose: local tag prefix used when `load_local_agents.py` builds packaged tool
# images into the host Docker engine for demo workflows.
# Default: agenthub-local
# Acceptable examples:
#   AGENTHUB_TOOL_IMAGE_TAG_PREFIX=agenthub-local
#   AGENTHUB_TOOL_IMAGE_TAG_PREFIX=registry.internal/agenthub
AGENTHUB_TOOL_IMAGE_TAG_PREFIX=agenthub-local
